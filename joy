n = int(input("输入几个数字："))
j=0
list_one = []
while (j<n):
    num=input("输入数字：")
    list_one.append(num)
    j=j+1
print(list_one)
list_one=[int(x) for x in list_one]
print(list_one)
sum=0
for i in list_one:
    sum=sum=sum+i
print(sum)
print(list(map(str,list_one)))
del sum
print(sum)
#map函数具有和for 相似的处理方式，但具有更高的可操作性。
